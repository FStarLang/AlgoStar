PULSE_ROOT ?= ../../FStar/pulse
KRML_HOME  ?= ../../FStar/karamel
include $(PULSE_ROOT)/mk/test.mk
OTHERFLAGS += --include ../common

# ── C extraction and test targets ──────────────────────────────────
CHAPTER_ID        = ch23
EXTRACT_DIR       = _output/c

KRML_INPUT_FILES  = _output/CLRS_Ch23_Prim_ImplTest.krml \
                    _output/CLRS_Ch23_Prim_Impl.krml \
                    _output/CLRS_Ch23_Kruskal_ImplTest.krml \
                    _output/CLRS_Ch23_Kruskal_Impl.krml \
                    _output/CLRS_Ch23_MST_Spec.krml \
                    _output/CLRS_Ch23_Prim_Spec.krml \
                    _output/CLRS_Ch23_Prim_Greedy.krml
KRML_BUNDLE_FLAGS = \
  -bundle 'CLRS.Ch23.Prim.ImplTest+CLRS.Ch23.Prim.Impl+CLRS.Ch23.Kruskal.ImplTest+CLRS.Ch23.Kruskal.Impl=CLRS.*[rename=Ch23_MST]'
KRML_WARN_FLAGS   = -warn-error -2-9-15-17
KRML_EXTRA_FLAGS  =
EXTRACT_C_FILES   = $(EXTRACT_DIR)/Ch23_MST.c
EXTRA_C_SOURCES   = fstar_support.c \
                    $(KRML_HOME)/krmllib/dist/generic/prims.c
TEST_EXE_NAME     = mst_test.exe

# Cancel Pulse's generic .krml → .c pattern rules for our extract dir
# (we use KaRaMeL batch extraction via autoclrs.test.mk instead)
$(EXTRACT_DIR)/%.krml:
	@true
$(EXTRACT_DIR)/%.c: $(EXTRACT_DIR)/%.krml
	@true

include ../autoclrs.test.mk

# ── Snapshot target ─────────────────────────────────────────────────
# Produces a self-contained snapshot/ directory with all extracted C/H
# files, handwritten test driver, and bundled KaRaMeL runtime headers.
# The snapshot can be built standalone: cd snapshot && make

SNAPSHOT_DIR = snapshot

.PHONY: snapshot
snapshot: $(EXTRACT_C_FILES)
	@echo "  [SNAPSHOT] Populating $(SNAPSHOT_DIR)/"
	@mkdir -p $(SNAPSHOT_DIR)/internal $(SNAPSHOT_DIR)/krml/internal
	@# ── Generated files (F* + KaRaMeL) ──
	@cp $(EXTRACT_DIR)/Ch23_MST.c          $(SNAPSHOT_DIR)/
	@cp $(EXTRACT_DIR)/Ch23_MST.h          $(SNAPSHOT_DIR)/
	@cp $(EXTRACT_DIR)/internal/Ch23_MST.h $(SNAPSHOT_DIR)/internal/
	@cp $(EXTRACT_DIR)/internal/Prims.h    $(SNAPSHOT_DIR)/internal/
	@# ── KaRaMeL runtime: prims implementation ──
	@cp $(KRML_HOME)/krmllib/dist/generic/prims.c      $(SNAPSHOT_DIR)/prims.c
	@# ── KaRaMeL runtime headers (bundled for standalone build) ──
	@cp $(KRML_HOME)/include/krmllib.h                  $(SNAPSHOT_DIR)/krmllib.h
	@cp $(KRML_HOME)/include/krml/internal/compat.h     $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_HOME)/include/krml/internal/target.h     $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_HOME)/include/krml/internal/callconv.h   $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_HOME)/include/krml/internal/builtin.h    $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_HOME)/include/krml/internal/debug.h      $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_HOME)/include/krml/internal/types.h      $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_HOME)/include/krml/lowstar_endianness.h  $(SNAPSHOT_DIR)/krml/
	@cp $(KRML_HOME)/include/krml/fstar_int.h           $(SNAPSHOT_DIR)/krml/
	@# ── KaRaMeL runtime support headers (from minimal + generic dist) ──
	@for f in $(KRML_HOME)/krmllib/dist/minimal/*.h; do cp "$$f" $(SNAPSHOT_DIR)/; done
	@cp $(KRML_HOME)/krmllib/dist/generic/Prims.h       $(SNAPSHOT_DIR)/Prims.h
	@cp $(KRML_HOME)/krmllib/dist/generic/FStar_Int32.h $(SNAPSHOT_DIR)/FStar_Int32.h
	@# ── Handwritten files (add prominent HANDWRITTEN header) ──
	@{ echo '/* ========================================================================'; \
	  echo '   HANDWRITTEN FILE — This file is NOT generated by F* or KaRaMeL.'; \
	  echo '   It is a manually written test driver for the extracted MST code.'; \
	  echo '   ======================================================================== */'; \
	  echo ''; \
	  cat main.c; } > $(SNAPSHOT_DIR)/main.c
	@{ echo '/* ========================================================================'; \
	  echo '   HANDWRITTEN FILE — This file is NOT generated by F* or KaRaMeL.'; \
	  echo '   It provides minimal runtime support for krml-extracted code.'; \
	  echo '   ======================================================================== */'; \
	  echo ''; \
	  cat fstar_support.c; } > $(SNAPSHOT_DIR)/fstar_support.c
	@echo "  [SNAPSHOT] Done. Build with: cd $(SNAPSHOT_DIR) && make"
