PULSE_ROOT ?= ../../FStar/pulse
KRML_HOME  ?= ../../FStar/karamel
include $(PULSE_ROOT)/mk/test.mk

# ── C extraction and test targets ──────────────────────────────────
CHAPTER_ID = ch11

# Per-module .krml extraction (canonical pattern from test.mk)
KRML_INPUT_FILES  = $(OUTPUT_DIR)/CLRS_Ch11_HashTable_Impl.krml \
                    $(OUTPUT_DIR)/CLRS_Ch11_HashTable_ImplTest.krml

# Bundle Impl into ImplTest (Impl functions become static)
KRML_BUNDLE_FLAGS = \
  -bundle 'CLRS.Ch11.HashTable.ImplTest=CLRS.Ch11.HashTable.Impl[rename=CLRS_Ch11_HashTable_ImplTest]' \
  -bundle 'FStar.*,Pulse.*,Prims,PulseCore.*,LowStar.*'
KRML_WARN_FLAGS   = -warn-error -2-9-15
KRML_EXTRA_FLAGS  = -add-include '"fstar_support.h"'
EXTRACT_C_FILES   = $(OUTPUT_DIR)/CLRS_Ch11_HashTable_ImplTest.c
EXTRA_C_SOURCES   = fstar_support.c \
                    $(KRML_HOME)/krmllib/dist/generic/prims.c

include ../autoclrs.test.mk

# Alias for backward compatibility
.PHONY: test
test: test-c

# ── Snapshot: self-contained C directory ────────────────────────────
# Creates snapshot/ with all extracted + handwritten C code and the
# krmllib headers needed to compile without F*/Pulse/KaRaMeL.

SNAPSHOT_DIR  = snapshot
KRML_INCLUDE  = $(KRML_HOME)/include
KRML_DIST_MIN = $(KRML_HOME)/krmllib/dist/minimal
KRML_DIST_GEN = $(KRML_HOME)/krmllib/dist/generic

.PHONY: snapshot
snapshot: extract
	@echo "=== Creating snapshot ==="
	@mkdir -p $(SNAPSHOT_DIR)/internal $(SNAPSHOT_DIR)/krml/internal
	@# ── Generated files (F* + KaRaMeL) ──
	@cp $(OUTPUT_DIR)/CLRS_Ch11_HashTable_ImplTest.c $(SNAPSHOT_DIR)/
	@cp $(OUTPUT_DIR)/CLRS_Ch11_HashTable_ImplTest.h $(SNAPSHOT_DIR)/
	@cp $(OUTPUT_DIR)/internal/FStar_Pulse_Prims_PulseCore_LowStar.h \
	    $(SNAPSHOT_DIR)/internal/
	@# ── Handwritten files (with prominent header) ──
	@for f in main.c fstar_support.c fstar_support.h; do \
	  printf '/* HANDWRITTEN: This file was written by hand, not generated by F* or KaRaMeL. */\n' \
	    > $(SNAPSHOT_DIR)/$$f; \
	  cat $$f >> $(SNAPSHOT_DIR)/$$f; \
	done
	@# ── KaRaMeL runtime: prims ──
	@cp $(KRML_DIST_GEN)/prims.c $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_GEN)/Prims.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_GEN)/FStar_Int32.h $(SNAPSHOT_DIR)/
	@# ── KaRaMeL headers: krmllib.h + krml/ ──
	@cp $(KRML_INCLUDE)/krmllib.h $(SNAPSHOT_DIR)/
	@cp $(KRML_INCLUDE)/krml/lowstar_endianness.h $(SNAPSHOT_DIR)/krml/
	@cp $(KRML_INCLUDE)/krml/fstar_int.h $(SNAPSHOT_DIR)/krml/
	@cp $(KRML_INCLUDE)/krml/c_endianness.h $(SNAPSHOT_DIR)/krml/
	@cp $(KRML_INCLUDE)/krml/internal/target.h $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_INCLUDE)/krml/internal/callconv.h $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_INCLUDE)/krml/internal/builtin.h $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_INCLUDE)/krml/internal/debug.h $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_INCLUDE)/krml/internal/types.h $(SNAPSHOT_DIR)/krml/internal/
	@cp $(KRML_INCLUDE)/krml/internal/compat.h $(SNAPSHOT_DIR)/krml/internal/
	@# ── KaRaMeL uint128 headers (needed by types.h) ──
	@cp $(KRML_DIST_MIN)/FStar_UInt128.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_MIN)/fstar_uint128_gcc64.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_MIN)/fstar_uint128_msvc.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_MIN)/fstar_uint128_struct_endianness.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_MIN)/FStar_UInt128_Verified.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_MIN)/FStar_UInt_8_16_32_64.h $(SNAPSHOT_DIR)/
	@cp $(KRML_DIST_MIN)/LowStar_Endianness.h $(SNAPSHOT_DIR)/
	@echo "=== Snapshot created in $(SNAPSHOT_DIR)/ ==="
	@echo "=== Building and testing snapshot ==="
	@$(MAKE) -C $(SNAPSHOT_DIR) test
