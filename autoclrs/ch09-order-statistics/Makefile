PULSE_ROOT ?= ../../pulse
include $(PULSE_ROOT)/mk/test.mk
# Explicitly disable optimize_let_vc and fly_deps for this chapter — they break
# quantifier instantiation in insert_sorted (CLRS.Ch09.PartialSelectionSort.Spec.fst)
OTHERFLAGS := $(subst --ext optimize_let_vc,,$(subst --ext fly_deps,,$(OTHERFLAGS))) --ext optimize_let_vc=false --ext fly_deps=false --include ../common

# ============================================================================
# C extraction & test targets
# ============================================================================
KRML_HOME ?= ../../krml/karamel
KRML_EXE  ?= $(KRML_HOME)/krml

# Modules to extract to .krml
KRML_MODULES = \
  CLRS_Ch09_MinMax_Impl \
  CLRS_Ch09_MinMax_ImplTest \
  CLRS_Ch09_PartialSelectionSort_Impl \
  CLRS_Ch09_PartialSelectionSort_ImplTest \
  CLRS_Ch09_Quickselect_Impl \
  CLRS_Ch09_Quickselect_ImplTest \
  CLRS_Ch09_SimultaneousMinMax_Impl \
  CLRS_Ch09_SimultaneousMinMax_ImplTest \
  CLRS_Ch09_SimultaneousMinMax_Spec \
  Pulse_Lib_BoundedIntegers

KRML_FILES = $(patsubst %,$(OUTPUT_DIR)/%.krml,$(KRML_MODULES))

# Extracted C source files (generated by krml)
EXTRACTED_C = \
  $(OUTPUT_DIR)/CLRS_Ch09_MinMax_Impl.c \
  $(OUTPUT_DIR)/CLRS_Ch09_PartialSelectionSort_Impl.c \
  $(OUTPUT_DIR)/CLRS_Ch09_Quickselect_Impl.c \
  $(OUTPUT_DIR)/CLRS_Ch09_SimultaneousMinMax_Impl.c \
  $(OUTPUT_DIR)/Pulse_Lib_BoundedIntegers.c

KRML_CC_FLAGS = \
  -I $(KRML_HOME)/krmllib/dist/minimal \
  -I $(KRML_HOME)/krmllib/dist/generic \
  -I $(KRML_HOME)/krmllib \
  -I $(KRML_HOME)/include \
  -I $(OUTPUT_DIR) \
  -Wno-parentheses -std=c11 -g \
  -D_BSD_SOURCE -D_DEFAULT_SOURCE

# Step 1: Extract all modules to .krml, then run krml to generate C
.PHONY: extract
extract: $(KRML_FILES)
	$(call msg, "KRML", "Ch09 algorithms")
	$(KRML_EXE) \
	  -faggressive-inlining \
	  -warn-error -9-10-11-15-17 \
	  -add-include '"krml/internal/compat.h"' \
	  -skip-makefiles -skip-linking \
	  -drop 'CLRS.Ch09.PartialSelectionSort.Spec,CLRS.Ch09.Quickselect.Spec,CLRS.Ch09.MinMax.Spec,CLRS.Common.Complexity' \
	  $(KRML_FILES) \
	  -tmpdir $(OUTPUT_DIR)

# Step 2: Compile the test executable
$(OUTPUT_DIR)/ch09_test: extract test_main.c krmlinit_override.c
	$(call msg, "CC", "ch09_test")
	$(CC) $(KRML_CC_FLAGS) \
	  -o $@ \
	  test_main.c \
	  krmlinit_override.c \
	  $(EXTRACTED_C) \
	  $(KRML_HOME)/krmllib/c/prims.c \
	  $(KRML_HOME)/krmllib/c/fstar_int32.c

# Step 3: Run the test
$(OUTPUT_DIR)/ch09_test.out: $(OUTPUT_DIR)/ch09_test
	$(call msg, "RUN", "ch09_test")
	./$< | tee $@
	@grep -q "11/11 tests passed" $@ || (echo "FAIL: not all tests passed" && exit 1)

.PHONY: test-c
test-c: $(OUTPUT_DIR)/ch09_test.out
