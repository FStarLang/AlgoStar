PULSE_ROOT ?= ../../FStar/pulse
KRML_HOME  ?= ../../FStar/karamel
STAGE3     ?= 1
include $(PULSE_ROOT)/mk/test.mk
OTHERFLAGS += --include ../common

# ── C extraction and test targets ──────────────────────────────────
CHAPTER_ID        = ch22
EXTRACT_DIR       = $(OUTPUT_DIR)/csrc

IMPLTEST_KRML = \
	$(OUTPUT_DIR)/CLRS_Ch22_ImplTestMain.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_BFS_ImplTest.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_DFS_ImplTest.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_TopologicalSort_ImplTest.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_BFS_Impl.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_DFS_Impl.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_TopologicalSort_Impl.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_TopologicalSort_Impl_Defs.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_Graph_Common.krml \
	$(OUTPUT_DIR)/CLRS_Ch22_TopologicalSort_Spec.krml

KRML_INPUT_FILES  = $(IMPLTEST_KRML)
KRML_BUNDLE_FLAGS = \
	-bundle 'CLRS.Ch22.ImplTestMain=CLRS.Ch22.*' \
	-bundle 'FStar.*,Pulse.*,PulseCore.*,Prims'
KRML_WARN_FLAGS   = -warn-error -2-9-11-15-17
KRML_EXTRA_FLAGS  = -add-include '"fstar_support.h"'
EXTRA_C_SOURCES   = fstar_support.c \
                    $(KRML_HOME)/krmllib/dist/generic/prims.c
EXTRACT_C_FILES   = $(EXTRACT_DIR)/CLRS_Ch22_ImplTestMain.c
TEST_EXE_NAME     = ch22_test

include ../autoclrs.test.mk

# ── Snapshot target ─────────────────────────────────────────────────
# Produces a self-contained snapshot/ directory with all generated C,
# handwritten support files, vendored KaRaMeL headers, and a Makefile
# that can build and run the tests without any F*/Pulse toolchain.

SNAPSHOT_DIR = snapshot

.PHONY: snapshot
snapshot: $(EXTRACT_C_FILES)
	$(call msg, "SNAPSHOT", "$(CHAPTER_ID)")
	@rm -rf $(SNAPSHOT_DIR)
	@mkdir -p $(SNAPSHOT_DIR)/internal
	@mkdir -p $(SNAPSHOT_DIR)/krmllib/include/krml/internal
	@mkdir -p $(SNAPSHOT_DIR)/krmllib/dist/minimal
	@mkdir -p $(SNAPSHOT_DIR)/krmllib/dist/generic
	@# ── Generated files (F* + KaRaMeL) ──
	cp $(EXTRACT_DIR)/CLRS_Ch22_ImplTestMain.c $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/CLRS_Ch22_ImplTestMain.h $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/internal/FStar_Pulse_PulseCore_Prims.h $(SNAPSHOT_DIR)/internal/
	@# ── Handwritten files (with prominent header comment) ──
	@echo '/*******************************************************************************' >  $(SNAPSHOT_DIR)/main.c
	@echo ' * HANDWRITTEN FILE — This file is NOT generated by F* or KaRaMeL.'             >> $(SNAPSHOT_DIR)/main.c
	@echo ' * It is a manually written test driver for the Ch22 extracted code.'            >> $(SNAPSHOT_DIR)/main.c
	@echo ' ******************************************************************************/' >> $(SNAPSHOT_DIR)/main.c
	cat main.c >> $(SNAPSHOT_DIR)/main.c
	@echo '/*******************************************************************************' >  $(SNAPSHOT_DIR)/fstar_support.c
	@echo ' * HANDWRITTEN FILE — This file is NOT generated by F* or KaRaMeL.'             >> $(SNAPSHOT_DIR)/fstar_support.c
	@echo ' * It provides manually written support stubs for the KaRaMeL runtime.'          >> $(SNAPSHOT_DIR)/fstar_support.c
	@echo ' ******************************************************************************/' >> $(SNAPSHOT_DIR)/fstar_support.c
	cat fstar_support.c >> $(SNAPSHOT_DIR)/fstar_support.c
	@echo '/*******************************************************************************' >  $(SNAPSHOT_DIR)/fstar_support.h
	@echo ' * HANDWRITTEN FILE — This file is NOT generated by F* or KaRaMeL.'             >> $(SNAPSHOT_DIR)/fstar_support.h
	@echo ' * It provides manually written support stubs for the KaRaMeL runtime.'          >> $(SNAPSHOT_DIR)/fstar_support.h
	@echo ' ******************************************************************************/' >> $(SNAPSHOT_DIR)/fstar_support.h
	cat fstar_support.h >> $(SNAPSHOT_DIR)/fstar_support.h
	@# ── Vendored KaRaMeL runtime headers ──
	cp $(KRML_HOME)/include/krmllib.h             $(SNAPSHOT_DIR)/krmllib/include/
	cp $(KRML_HOME)/include/krml/internal/compat.h   $(SNAPSHOT_DIR)/krmllib/include/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/target.h   $(SNAPSHOT_DIR)/krmllib/include/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/callconv.h $(SNAPSHOT_DIR)/krmllib/include/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/builtin.h  $(SNAPSHOT_DIR)/krmllib/include/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/debug.h    $(SNAPSHOT_DIR)/krmllib/include/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/types.h    $(SNAPSHOT_DIR)/krmllib/include/krml/internal/
	cp $(KRML_HOME)/include/krml/lowstar_endianness.h $(SNAPSHOT_DIR)/krmllib/include/krml/
	cp $(KRML_HOME)/include/krml/fstar_int.h          $(SNAPSHOT_DIR)/krmllib/include/krml/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_gcc64.h            $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_msvc.h             $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_struct_endianness.h $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt128_Verified.h         $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt128.h                  $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt_8_16_32_64.h          $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/minimal/LowStar_Endianness.h            $(SNAPSHOT_DIR)/krmllib/dist/minimal/
	cp $(KRML_HOME)/krmllib/dist/generic/Prims.h       $(SNAPSHOT_DIR)/krmllib/dist/generic/
	cp $(KRML_HOME)/krmllib/dist/generic/FStar_Int32.h $(SNAPSHOT_DIR)/krmllib/dist/generic/
	cp $(KRML_HOME)/krmllib/dist/generic/prims.c       $(SNAPSHOT_DIR)/krmllib/dist/generic/
	@echo "Snapshot created in $(SNAPSHOT_DIR)/"
	@# ── Standalone Makefile ──
	cp snapshot.Makefile $(SNAPSHOT_DIR)/Makefile
