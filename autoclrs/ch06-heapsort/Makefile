include ../config.mk
include $(PULSE_ROOT)/mk/test.mk

# ── C extraction and test targets ──────────────────────────────────────
CHAPTER_ID       = ch06
KRML_INPUT_FILES = $(OUTPUT_DIR)/CLRS_Ch06_Heap_Impl.krml \
                   $(OUTPUT_DIR)/CLRS_Ch06_Heap_ImplTest.krml \
                   $(OUTPUT_DIR)/Pulse_Lib_BoundedIntegers.krml
KRML_BUNDLE_FLAGS = \
  -bundle 'CLRS.Ch06.Heap.ImplTest=CLRS.Ch06.Heap.*,Pulse.Lib.BoundedIntegers' \
  -bundle 'FStar.*,Pulse.*,PulseCore.*,Prims'
EXTRACT_C_FILES  = $(EXTRACT_DIR)/CLRS_Ch06_Heap_ImplTest.c
EXTRA_C_SOURCES  = fstar_support.c \
                   $(KRML_HOME)/krmllib/dist/generic/prims.c
CC_EXTRA_FLAGS   = -O2
TEST_EXE_NAME    = test_heapsort

include ../autoclrs.test.mk

# ── Snapshot target ─────────────────────────────────────────────────
# Produces a self-contained snapshot/ directory with all extracted C,
# vendored krmllib headers, handwritten driver code, and a Makefile
# that builds and runs tests without the F*/KaRaMeL toolchain.

SNAPSHOT_DIR = snapshot

.PHONY: snapshot
snapshot: $(EXTRACT_C_FILES)
	$(call msg, "SNAPSHOT", "$(CHAPTER_ID)")
	@mkdir -p $(SNAPSHOT_DIR)/internal $(SNAPSHOT_DIR)/krml/internal
	@# ── Generated files from F* + KaRaMeL ──
	cp $(EXTRACT_DIR)/CLRS_Ch06_Heap_ImplTest.c  $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/CLRS_Ch06_Heap_ImplTest.h  $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/krmlinit.c                  $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/krmlinit.h                  $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/internal/CLRS_Ch06_Heap_ImplTest.h     $(SNAPSHOT_DIR)/internal/
	cp $(EXTRACT_DIR)/internal/FStar_Pulse_PulseCore_Prims.h $(SNAPSHOT_DIR)/internal/
	@# ── Vendored krmllib headers ──
	cp $(KRML_HOME)/include/krmllib.h                  $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/include/krml/lowstar_endianness.h  $(SNAPSHOT_DIR)/krml/
	cp $(KRML_HOME)/include/krml/fstar_int.h           $(SNAPSHOT_DIR)/krml/
	cp $(KRML_HOME)/include/krml/c_endianness.h        $(SNAPSHOT_DIR)/krml/
	cp $(KRML_HOME)/include/krml/internal/builtin.h    $(SNAPSHOT_DIR)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/callconv.h   $(SNAPSHOT_DIR)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/compat.h     $(SNAPSHOT_DIR)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/debug.h      $(SNAPSHOT_DIR)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/target.h     $(SNAPSHOT_DIR)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/types.h      $(SNAPSHOT_DIR)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/wasmsupport.h $(SNAPSHOT_DIR)/krml/internal/
	@# ── Vendored krmllib dist files (for uint128 and Prims) ──
	@# uint128 headers go in root so unqualified includes from types.h resolve
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_gcc64.h            $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_msvc.h             $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt128_Verified.h         $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_struct_endianness.h $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt_8_16_32_64.h         $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt128.h                  $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/LowStar_Endianness.h            $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/generic/Prims.h       $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/generic/FStar_Int32.h $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/generic/prims.c       $(SNAPSHOT_DIR)/
	@# ── Handwritten files (add prominent banner) ──
	@printf '/*\n * !! HANDWRITTEN — NOT GENERATED !!\n *\n * This file is handwritten (not generated by F* / KaRaMeL).\n * All other .c/.h files in this directory are machine-generated.\n */\n' > $(SNAPSHOT_DIR)/.hw_banner
	cat $(SNAPSHOT_DIR)/.hw_banner main.c          > $(SNAPSHOT_DIR)/main.c
	cat $(SNAPSHOT_DIR)/.hw_banner fstar_support.c > $(SNAPSHOT_DIR)/fstar_support.c
	rm -f $(SNAPSHOT_DIR)/.hw_banner
	@echo "Snapshot created in $(SNAPSHOT_DIR)/"
