# Makefile for CLRS Ch06 Heapsort — Standalone Snapshot
#
# This directory is self-contained: it includes all generated C code
# (from F* + KaRaMeL extraction) and vendored krmllib headers.
# No F*, Pulse, or KaRaMeL installation is required to build.
#
# Usage:
#   make          # build and run tests
#   make build    # build only
#   make test     # build and run
#   make clean    # remove build artifacts

CC       ?= gcc
CFLAGS    = -std=c11 -Wall -g -fwrapv -O2 \
            -D_BSD_SOURCE -D_DEFAULT_SOURCE \
            -Wno-unused-variable -Wno-unused-parameter \
            -Wno-parentheses
INCLUDES  = -I .
EXE       = test_heapsort

# Generated by F* + KaRaMeL (krmlinit.c is not compiled — main.c provides krmlinit_globals)
GENERATED_C = CLRS_Ch06_Heap_ImplTest.c

# Vendored krmllib support
KRMLLIB_C   = prims.c

# Handwritten
HANDWRITTEN_C = main.c fstar_support.c

SOURCES = $(HANDWRITTEN_C) $(GENERATED_C) $(KRMLLIB_C)

.PHONY: all build test clean

all: test

build: $(EXE)

$(EXE): $(SOURCES)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $(SOURCES)

test: $(EXE)
	@echo "--- Running Ch06 Heapsort tests ---"
	./$(EXE)

clean:
	rm -f $(EXE)
