PULSE_ROOT ?= ../../FStar/pulse
KRML_HOME  ?= ../../FStar/karamel
STAGE3     ?= 1
export STAGE3
OTHERFLAGS += --include ../common
include $(PULSE_ROOT)/mk/test.mk

# ========== C extraction and test targets ==========
CHAPTER_ID       = ch21

# Explicit .krml extraction rules (these modules need manual extraction)
$(OUTPUT_DIR)/CLRS_Ch21_UnionFind_ImplTest.krml: _cache/CLRS.Ch21.UnionFind.ImplTest.fst.checked
	$(call msg, "EXTRACT", "CLRS.Ch21.UnionFind.ImplTest")
	$(FSTAR) $< --codegen krml --extract_module CLRS.Ch21.UnionFind.ImplTest

$(OUTPUT_DIR)/CLRS_Ch21_UnionFind_Impl.krml: _cache/CLRS.Ch21.UnionFind.Impl.fst.checked
	$(call msg, "EXTRACT", "CLRS.Ch21.UnionFind.Impl")
	$(FSTAR) $< --codegen krml --extract_module CLRS.Ch21.UnionFind.Impl

KRML_INPUT_FILES  = $(OUTPUT_DIR)/CLRS_Ch21_UnionFind_ImplTest.krml \
                    $(OUTPUT_DIR)/CLRS_Ch21_UnionFind_Impl.krml
KRML_BUNDLE_FLAGS = \
  -bundle 'CLRS.Ch21.UnionFind.ImplTest=CLRS.Ch21.UnionFind.*' \
  -bundle 'FStar.*,Pulse.*,PulseCore.*,Prims,C'
KRML_WARN_FLAGS   = -warn-error '-2-9-11-15-17'
EXTRACT_C_FILES   = $(EXTRACT_DIR)/CLRS_Ch21_UnionFind_ImplTest.c
KRML_EXTRA_INPUTS = $(wildcard $(KRML_HOME)/krmllib/.extract/*.krml)
EXTRA_C_SOURCES   = $(KRML_HOME)/krmllib/dist/generic/c.c
TEST_EXE_NAME     = test_union_find

include ../autoclrs.test.mk

# ========== Snapshot target ==========
# Produces a self-contained C snapshot in snapshot/ with all extracted
# .c/.h files, krmllib headers, a handwritten test driver, and a Makefile.

SNAPSHOT_DIR = snapshot

.PHONY: snapshot
snapshot: $(EXTRACT_C_FILES)
	@echo "=== Building snapshot ==="
	@mkdir -p $(SNAPSHOT_DIR)/krml/internal
	@# Copy generated .c and .h files
	cp $(EXTRACT_DIR)/CLRS_Ch21_UnionFind_ImplTest.c $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/CLRS_Ch21_UnionFind_ImplTest.h $(SNAPSHOT_DIR)/
	@# Copy handwritten test driver (with prominent header added)
	@echo '/* HANDWRITTEN FILE — This is the manually written test driver, */' > $(SNAPSHOT_DIR)/main.c
	@echo '/* not generated by F* + KaRaMeL.                               */' >> $(SNAPSHOT_DIR)/main.c
	@echo '' >> $(SNAPSHOT_DIR)/main.c
	cat $(TEST_MAIN) >> $(SNAPSHOT_DIR)/main.c
	@# Copy krmllib headers (from karamel/include/)
	cp $(KRML_HOME)/include/krmllib.h $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/include/krml/fstar_int.h $(SNAPSHOT_DIR)/krml/
	cp $(KRML_HOME)/include/krml/lowstar_endianness.h $(SNAPSHOT_DIR)/krml/
	cp -a $(KRML_HOME)/include/krml/internal/builtin.h    $(SNAPSHOT_DIR)/krml/internal/
	cp -a $(KRML_HOME)/include/krml/internal/callconv.h   $(SNAPSHOT_DIR)/krml/internal/
	cp -a $(KRML_HOME)/include/krml/internal/compat.h     $(SNAPSHOT_DIR)/krml/internal/
	cp -a $(KRML_HOME)/include/krml/internal/debug.h      $(SNAPSHOT_DIR)/krml/internal/
	cp -a $(KRML_HOME)/include/krml/internal/target.h     $(SNAPSHOT_DIR)/krml/internal/
	cp -a $(KRML_HOME)/include/krml/internal/types.h      $(SNAPSHOT_DIR)/krml/internal/
	@# Copy krmllib/dist/minimal headers (transitively included)
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt128.h        $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt_8_16_32_64.h $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/LowStar_Endianness.h   $(SNAPSHOT_DIR)/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_gcc64.h  $(SNAPSHOT_DIR)/
	@echo "=== Snapshot built in $(SNAPSHOT_DIR)/ ==="
