include ../config.mk
OTHERFLAGS += --split_queries always
include $(PULSE_ROOT)/mk/test.mk

# ── C extraction and test targets ──────────────────────────────────
CHAPTER_ID        = ch24
EXTRACT_DIR       = _output/c

KRML_INPUT_FILES  = $(OUTPUT_DIR)/CLRS_Ch24_BellmanFord_ImplTest.krml \
                    $(OUTPUT_DIR)/CLRS_Ch24_BellmanFord_Impl.krml \
                    $(OUTPUT_DIR)/CLRS_Ch24_Dijkstra_ImplTest.krml \
                    $(OUTPUT_DIR)/CLRS_Ch24_Dijkstra_Impl.krml \
                    $(OUTPUT_DIR)/CLRS_Ch24_Dijkstra.krml \
                    $(OUTPUT_DIR)/CLRS_Ch24_ShortestPath_Inf.krml \
                    $(OUTPUT_DIR)/CLRS_Ch24_ShortestPath_Spec.krml
KRML_BUNDLE_FLAGS = \
  -bundle 'CLRS.Ch24.BellmanFord.ImplTest+CLRS.Ch24.Dijkstra.ImplTest=CLRS.Ch24.*[rename=Ch24_SSSP]' \
  -bundle 'FStar.*,Pulse.*,PulseCore.*,Prims'
KRML_WARN_FLAGS   = -warn-error -2-9-11-15-17
KRML_EXTRA_FLAGS  =
EXTRACT_C_FILES   = $(EXTRACT_DIR)/Ch24_SSSP.c
EXTRA_C_SOURCES   = fstar_support.c \
                    $(KRML_HOME)/krmllib/dist/generic/prims.c \
                    $(EXTRACT_DIR)/krmlinit.c
CC_EXTRA_FLAGS    = -ffunction-sections -fdata-sections
EXTRA_LINK_LIBS   = -Wl,--gc-sections
TEST_EXE_NAME     = test_ch24

# Cancel Pulse's generic .krml → .c pattern rules for our extract dir
# (we use KaRaMeL batch extraction via autoclrs.test.mk instead)
$(EXTRACT_DIR)/%.krml:
	@true
$(EXTRACT_DIR)/%.c: $(EXTRACT_DIR)/%.krml
	@true

include ../autoclrs.test.mk

# ── Snapshot target ─────────────────────────────────────────────────
# Produces a self-contained snapshot/ directory with all extracted C,
# handwritten driver code, and KaRaMeL runtime headers.  The snapshot
# can be compiled and tested without F*, Pulse, or KaRaMeL.

SNAPSHOT_DIR = snapshot
SNAPSHOT_KRML_INC = $(SNAPSHOT_DIR)/krml_include

.PHONY: snapshot
snapshot: $(EXTRACT_C_FILES)
	@echo "=== Creating self-contained snapshot ==="
	@# ── Generated files from KaRaMeL extraction ──
	@mkdir -p $(SNAPSHOT_DIR)/internal
	cp $(EXTRACT_DIR)/Ch24_SSSP.c   $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/Ch24_SSSP.h   $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/krmlinit.c    $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/krmlinit.h    $(SNAPSHOT_DIR)/
	cp $(EXTRACT_DIR)/internal/Ch24_SSSP.h                 $(SNAPSHOT_DIR)/internal/
	cp $(EXTRACT_DIR)/internal/FStar_Pulse_PulseCore_Prims.h $(SNAPSHOT_DIR)/internal/
	@# ── KaRaMeL runtime (prims.c + headers) ──
	cp $(KRML_HOME)/krmllib/dist/generic/prims.c           $(SNAPSHOT_DIR)/
	@mkdir -p $(SNAPSHOT_KRML_INC)/krml/internal
	cp $(KRML_HOME)/include/krmllib.h                      $(SNAPSHOT_KRML_INC)/
	cp $(KRML_HOME)/include/krml/fstar_int.h               $(SNAPSHOT_KRML_INC)/krml/
	cp $(KRML_HOME)/include/krml/lowstar_endianness.h      $(SNAPSHOT_KRML_INC)/krml/
	cp $(KRML_HOME)/include/krml/internal/builtin.h        $(SNAPSHOT_KRML_INC)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/callconv.h       $(SNAPSHOT_KRML_INC)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/compat.h         $(SNAPSHOT_KRML_INC)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/debug.h          $(SNAPSHOT_KRML_INC)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/target.h         $(SNAPSHOT_KRML_INC)/krml/internal/
	cp $(KRML_HOME)/include/krml/internal/types.h          $(SNAPSHOT_KRML_INC)/krml/internal/
	cp $(KRML_HOME)/krmllib/dist/generic/Prims.h           $(SNAPSHOT_KRML_INC)/
	cp $(KRML_HOME)/krmllib/dist/generic/FStar_Int32.h     $(SNAPSHOT_KRML_INC)/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt128.h   $(SNAPSHOT_KRML_INC)/
	cp $(KRML_HOME)/krmllib/dist/minimal/FStar_UInt_8_16_32_64.h $(SNAPSHOT_KRML_INC)/
	cp $(KRML_HOME)/krmllib/dist/minimal/LowStar_Endianness.h   $(SNAPSHOT_KRML_INC)/
	cp $(KRML_HOME)/krmllib/dist/minimal/fstar_uint128_gcc64.h   $(SNAPSHOT_KRML_INC)/
	@# ── Handwritten files (add prominent header comment) ──
	@echo '/* !!  HANDWRITTEN  -- not generated by F* or KaRaMeL  !! */' >  $(SNAPSHOT_DIR)/main.c
	@echo '/* Test driver for verified SSSP algorithms (Ch24).        */' >> $(SNAPSHOT_DIR)/main.c
	@echo ''                                                              >> $(SNAPSHOT_DIR)/main.c
	@cat main.c                                                           >> $(SNAPSHOT_DIR)/main.c
	@echo '/* !!  HANDWRITTEN  -- not generated by F* or KaRaMeL  !! */' >  $(SNAPSHOT_DIR)/fstar_support.c
	@echo '/* Minimal support for krml-extracted code.                */' >> $(SNAPSHOT_DIR)/fstar_support.c
	@echo ''                                                              >> $(SNAPSHOT_DIR)/fstar_support.c
	@cat fstar_support.c                                                  >> $(SNAPSHOT_DIR)/fstar_support.c
	@echo "=== Snapshot created in $(SNAPSHOT_DIR)/ ==="
