# Makefile for Ch10 snapshot — self-contained C build
#
# This directory contains the KaRaMeL-extracted C code for the Ch10
# elementary data structures (Stack, Queue, Singly Linked List, Doubly
# Linked List) plus the minimal krmllib runtime headers needed to compile.
#
# Usage:
#   make          # build and run the tests
#   make build    # compile only
#   make test     # compile and run
#   make clean    # remove build artifacts

CC       ?= gcc
CFLAGS    = -std=c11 -Wall -g -fwrapv \
            -D_BSD_SOURCE -D_DEFAULT_SOURCE \
            -Wno-unused-variable -Wno-unused-parameter \
            -Wno-parentheses

INCLUDES  = -I . -I krmllib

# Extracted C sources (generated by F* + KaRaMeL)
EXTRACTED_C = \
  CLRS_Ch10_Stack_ImplTest.c \
  CLRS_Ch10_Queue_ImplTest.c \
  CLRS_Ch10_SinglyLinkedList_ImplTest.c \
  CLRS_Ch10_DLL_ImplTest.c

# KaRaMeL runtime support
KRMLLIB_C = \
  krmllib/prims.c \
  krmllib/fstar_int32.c

# Handwritten test driver
MAIN      = main.c

EXE       = ch10_test

.PHONY: all build test clean

all: test

build: $(EXE)

$(EXE): $(MAIN) $(EXTRACTED_C) $(KRMLLIB_C)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $^

test: $(EXE)
	./$(EXE)

clean:
	rm -f $(EXE)
