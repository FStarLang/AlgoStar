# Ch15 Dynamic Programming — Standalone snapshot Makefile
#
# This snapshot contains C code extracted from verified Pulse/F* implementations
# of CLRS Chapter 15 algorithms (Rod Cutting, LCS, Matrix Chain Multiplication)
# via F* --codegen krml and KaRaMeL, plus the krmllib support headers needed
# to compile without an external KaRaMeL installation.
#
# Usage:
#   make          # build and run tests
#   make build    # build only
#   make run      # run tests (builds first if needed)
#   make clean    # remove build artifacts

CC       ?= gcc
CFLAGS   := -std=c11 -Wall -g -fwrapv \
            -D_BSD_SOURCE -D_DEFAULT_SOURCE \
            -Wno-unused-variable -Wno-unused-parameter \
            -Wno-parentheses

INCLUDES := -I . -I krmllib/dist/minimal -I krmllib/dist/generic -I krmllib

# Extracted C sources (generated by F* + KaRaMeL)
EXTRACTED_SRCS = \
  RodCutting_ImplTest.c \
  LCS_ImplTest.c \
  MatrixChain_ImplTest.c \
  Support.c \
  krmlinit.c \
  krmllib/dist/generic/prims.c \
  krmllib/dist/generic/fstar_int32.c

# Handwritten test driver
MAIN_SRC = main.c

EXE = ch15_test

.PHONY: all build run clean

all: run

build: $(EXE)

$(EXE): $(MAIN_SRC) $(EXTRACTED_SRCS)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $^

run: $(EXE)
	./$(EXE)

clean:
	rm -f $(EXE)
