module CLRS.Ch35.VertexCover.Spec

open FStar.Mul
open FStar.List.Tot

(*** Type definitions ***)

// Vertex identifier (just nat)
// Edge represented as a pair of vertices (nat * nat)

// Adjacency matrix: adj[u*n+v] != 0 means edge (u,v) exists
type adj_matrix = list int

// Cover: boolean array where cover[v] = true means v is in the cover
type cover_t = list bool

// Edge type
type edge_t = (nat & nat)

// Matching: list of edges with no shared endpoints
type matching_t = list edge_t

(*** Helper functions ***)

// Get element at index in list
let rec get (#a:Type) (l:list a) (i:nat{i < length l}) : a =
  match l with
  | hd :: tl -> if i = 0 then hd else get tl (i - 1)

// Check if edge exists in adjacency matrix
let has_edge (adj:adj_matrix) (n:nat{n > 0}) (u v:nat{u < n /\ v < n}) : bool =
  let idx = u * n + v in
  if idx < length adj then
    get adj idx <> 0
  else false

// Check if vertex is in cover
let in_cover (cover:cover_t) (v:nat{v < length cover}) : bool =
  get cover v

// Count number of vertices in cover
let rec cover_size (cover:cover_t) : nat =
  match cover with
  | [] -> 0
  | hd :: tl -> (if hd then 1 else 0) + cover_size tl

// Count edges in matching
let matching_size (m:matching_t) : nat = length m

(*** Core predicates ***)

// A cover is valid if every edge has at least one endpoint in the cover
let is_valid_edge_covered (adj:adj_matrix) (n:nat{n > 0}) (cover:cover_t{length cover = n}) 
                          (u v:nat{u < n /\ v < n /\ u < v}) : Type0 =
  has_edge adj n u v ==> (in_cover cover u \/ in_cover cover v)

let is_valid_cover (adj:adj_matrix) (n:nat{n > 0}) (cover:cover_t{length cover = n}) : Type0 =
  forall (u v:nat). u < n /\ v < n /\ u < v ==> is_valid_edge_covered adj n cover u v

// Check if two edges share an endpoint
let edges_disjoint (e1 e2:edge_t) : Type0 =
  let (u1, v1) = e1 in
  let (u2, v2) = e2 in
  u1 <> u2 /\ u1 <> v2 /\ v1 <> u2 /\ v1 <> v2

// Check if all edges in a list are pairwise disjoint
let rec all_edges_disjoint (m:matching_t) : Type0 =
  match m with
  | [] -> True
  | e :: rest -> 
      (forall (e':edge_t). mem e' rest ==> edges_disjoint e e') /\
      all_edges_disjoint rest

// A matching is a set of edges with no shared endpoints
let is_valid_matching (adj:adj_matrix) (n:nat{n > 0}) (m:matching_t) : Type0 =
  (forall (e:edge_t). mem e m ==> (
    let (u, v) = e in
    u < n /\ v < n /\ u < v /\ has_edge adj n u v
  )) /\
  all_edges_disjoint m

(*** Algorithm specification ***)

// State during algorithm execution
type algo_state = {
  cover: cover_t;
  matching: matching_t;
}

// Initial state
let rec init_list (n:nat) (f:nat -> 'a) : list 'a =
  if n = 0 then []
  else f (n - 1) :: init_list (n - 1) f

let initial_state (n:nat{n > 0}) : algo_state = {
  cover = init_list n (fun _ -> false);
  matching = [];
}

// Update cover to include vertex v
let rec update_cover (cover:cover_t) (v:nat{v < length cover}) : cover_t =
  match cover with
  | [] -> []
  | hd :: tl -> 
      if v = 0 then true :: tl
      else hd :: update_cover tl (v - 1)

// Lemma: update_cover preserves length
let rec update_cover_length (cover:cover_t) (v:nat{v < length cover})
  : Lemma (length (update_cover cover v) = length cover) =
  match cover with
  | [] -> ()
  | hd :: tl -> if v = 0 then () else update_cover_length tl (v - 1)

// Lemma: update_cover sets the bit at position v to true
let rec update_cover_sets_bit (cover:cover_t) (v:nat{v < length cover})
  : Lemma (ensures (let uc = update_cover cover v in
                    length uc = length cover /\
                    get uc v = true)) =
  match cover with
  | [] -> ()
  | hd :: tl -> if v = 0 then () else (
      update_cover_sets_bit tl (v - 1);
      update_cover_length tl (v - 1)
    )

// Process edge (u,v): if uncovered, add both endpoints to cover and edge to matching
let process_edge (adj:adj_matrix) (n:nat{n > 0}) 
                 (u v:nat{u < n /\ v < n /\ u < v})
                 (state:algo_state{length state.cover = n}) : algo_state =
  if has_edge adj n u v && not (in_cover state.cover u) && not (in_cover state.cover v) then (
    update_cover_length state.cover u;
    let cover1 = update_cover state.cover u in
    update_cover_length cover1 v;
    let new_cover = update_cover cover1 v in
    { cover = new_cover; matching = (u, v) :: state.matching }
  )
  else
    state

// Process all edges with u < v
let rec process_edges (adj:adj_matrix) (n:nat{n > 0}) 
                      (u v:nat{u < n /\ v <= n})
                      (state:algo_state{length state.cover = n}) 
                      (fuel:nat) : algo_state =
  if fuel = 0 then state
  else if v = n then
    if u + 1 < n then
      process_edges adj n (u + 1) (u + 2) state (fuel - 1)
    else
      state
  else if v <= u then
    process_edges adj n u (v + 1) state (fuel - 1)
  else
    let new_state = process_edge adj n u v state in
    process_edges adj n u (v + 1) new_state (fuel - 1)

// Run the approximation algorithm
let approx_vertex_cover (adj:adj_matrix) (n:nat{n > 0}) : algo_state =
  let fuel = n * n in
  process_edges adj n 0 1 (initial_state n) fuel

(*** Key lemmas ***)

// Lemma: After processing an edge, if it was added to matching, both endpoints are in cover
let process_edge_covers_matching (adj:adj_matrix) (n:nat{n > 0})
                                 (u v:nat{u < n /\ v < n /\ u < v})
                                 (state:algo_state{length state.cover = n})
  : Lemma (requires True)
          (ensures (
            let new_state = process_edge adj n u v state in
            forall (e:edge_t). mem e new_state.matching /\ not (mem e state.matching) ==>
              (let (x, y) = e in
               in_cover new_state.cover x /\ in_cover new_state.cover y)
          )) =
  ()

// Lemma: The matching created by the algorithm has disjoint edges
// This is the key property: when we add both endpoints of an edge to the cover,
// we ensure no future edges will share vertices with this edge
let rec process_edges_maintains_disjoint (adj:adj_matrix) (n:nat{n > 0})
                                         (u v:nat{u < n /\ v <= n})
                                         (state:algo_state{length state.cover = n})
                                         (fuel:nat)
  : Lemma (requires all_edges_disjoint state.matching)
          (ensures (
            let final_state = process_edges adj n u v state fuel in
            all_edges_disjoint final_state.matching
          ))
          (decreases fuel) =
  if fuel = 0 then ()
  else if v = n then
    if u + 1 < n then
      process_edges_maintains_disjoint adj n (u + 1) (u + 2) state (fuel - 1)
    else ()
  else if v <= u then
    process_edges_maintains_disjoint adj n u (v + 1) state (fuel - 1)
  else
    let new_state = process_edge adj n u v state in
    // After processing edge (u,v), if it was added, u and v are now covered
    // So no future edges will share vertices with (u,v)
    process_edges_maintains_disjoint adj n u (v + 1) new_state (fuel - 1)

// Lemma: The algorithm produces a valid matching
let approx_produces_valid_matching (adj:adj_matrix) (n:nat{n > 0})
  : Lemma (
      let result = approx_vertex_cover adj n in
      is_valid_matching adj n result.matching
    ) =
  process_edges_maintains_disjoint adj n 0 1 (initial_state n) (n * n)

// Lemma: The algorithm produces a valid cover
let rec process_edges_produces_valid_cover (adj:adj_matrix) (n:nat{n > 0})
                                           (u v:nat{u < n /\ v <= n})
                                           (state:algo_state{length state.cover = n})
                                           (fuel:nat)
  : Lemma (requires (
            forall (e:edge_t). mem e state.matching ==>
              (let (x, y) = e in 
               x < n /\ y < n /\ in_cover state.cover x /\ in_cover state.cover y)
          ))
          (ensures (
            let final = process_edges adj n u v state fuel in
            forall (e:edge_t). mem e final.matching ==>
              (let (x, y) = e in
               x < n /\ y < n /\ in_cover final.cover x /\ in_cover final.cover y)
          ))
          (decreases fuel) =
  if fuel = 0 then ()
  else if v = n then
    if u + 1 < n then
      process_edges_produces_valid_cover adj n (u + 1) (u + 2) state (fuel - 1)
    else ()
  else if v <= u then
    process_edges_produces_valid_cover adj n u (v + 1) state (fuel - 1)
  else
    let new_state = process_edge adj n u v state in
    process_edges_produces_valid_cover adj n u (v + 1) new_state (fuel - 1)

// Lemma: The matching lower bound - any cover must be at least as large as any matching
// Proof: Each edge in a matching needs at least one endpoint covered.
//        Since edges in a matching are disjoint, we need at least |M| distinct vertices.
let matching_lower_bound (adj:adj_matrix) (n:nat{n > 0})
                         (cover:cover_t{length cover = n})
                         (m:matching_t)
  : Lemma (requires (
            is_valid_cover adj n cover /\
            is_valid_matching adj n m
          ))
          (ensures cover_size cover >= matching_size m) =
  // Each edge in matching needs at least one endpoint in cover
  // Since edges are disjoint, this gives us a lower bound
  admit() // This requires counting argument with cardinality

// Lemma: Cover size equals 2 * matching size for the algorithm's output
let rec process_edges_cover_size_eq_twice_matching (adj:adj_matrix) (n:nat{n > 0})
                                                    (u v:nat{u < n /\ v <= n})
                                                    (state:algo_state{length state.cover = n})
                                                    (fuel:nat)
  : Lemma (requires True)
          (ensures (
            let final = process_edges adj n u v state fuel in
            // For each edge added to matching, we add exactly 2 vertices to cover
            True // Simplified for now
          ))
          (decreases fuel) =
  if fuel = 0 then ()
  else if v = n then
    if u + 1 < n then
      process_edges_cover_size_eq_twice_matching adj n (u + 1) (u + 2) state (fuel - 1)
    else ()
  else if v <= u then
    process_edges_cover_size_eq_twice_matching adj n u (v + 1) state (fuel - 1)
  else
    let new_state = process_edge adj n u v state in
    process_edges_cover_size_eq_twice_matching adj n u (v + 1) new_state (fuel - 1)

(*** Main theorem: 2-approximation ratio ***)

// Theorem 35.1 (CLRS): APPROX-VERTEX-COVER is a 2-approximation algorithm
let approx_vertex_cover_is_2_approximation (adj:adj_matrix) (n:nat{n > 0})
  : Lemma (
      let result = approx_vertex_cover adj n in
      let c = result.cover in
      let m = result.matching in
      // 1. The output is a valid cover
      is_valid_cover adj n c /\
      // 2. The matching is valid
      is_valid_matching adj n m /\
      // 3. Cover size = 2 * matching size
      cover_size c = 2 * matching_size m /\
      // 4. For any valid cover C': |C'| >= |M| (matching lower bound)
      (forall (cover':cover_t{length cover' = n}).
        is_valid_cover adj n cover' ==> cover_size cover' >= matching_size m) /\
      // 5. Therefore: |C| = 2|M| <= 2|OPT|
      (forall (opt:cover_t{length opt = n}).
        is_valid_cover adj n opt ==>
        cover_size c <= 2 * cover_size opt)
    ) =
  let result = approx_vertex_cover adj n in
  approx_produces_valid_matching adj n;
  process_edges_produces_valid_cover adj n 0 1 (initial_state n) (n * n);
  process_edges_cover_size_eq_twice_matching adj n 0 1 (initial_state n) (n * n);
  // The key insight: opt must cover all edges in our matching
  // Since matching edges are disjoint, opt needs at least |M| vertices
  // Our cover has exactly 2|M| vertices
  // Therefore: |C| = 2|M| <= 2|OPT|
  admit() // Final assembly requires matching_lower_bound and size equality

// Corollary: The approximation ratio is at most 2
let approx_ratio_at_most_2 (adj:adj_matrix) (n:nat{n > 0})
  : Lemma (
      let result = approx_vertex_cover adj n in
      let c = result.cover in
      forall (opt:cover_t{length opt = n}).
        is_valid_cover adj n opt ==>
        cover_size c <= 2 * cover_size opt
    ) =
  approx_vertex_cover_is_2_approximation adj n
