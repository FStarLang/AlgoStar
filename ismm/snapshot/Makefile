# Makefile for ISMM verified C snapshot
#
# This directory contains the C code extracted from the verified Pulse
# implementation of "Reference Counting Deeply Immutable Data Structures
# with Cycles" (ISMM '24).  All .c/.h files were generated by KaRaMeL
# from the verified F*/Pulse sources in the parent directory.
#
# The krmllib headers bundled here are the minimal subset required.
# No external dependencies beyond a C11 compiler are needed.

CC      ?= gcc
CFLAGS  := -std=c11 -Wall -Wno-unused-variable -Wno-parentheses \
           -Wno-implicit-function-declaration -O2 \
           -I. -Ikrml -Ikrml/internal \
           -DKRML_HOST_MALLOC=malloc \
           -DKRML_HOST_FREE=free \
           -DKRML_HOST_EXIT=exit

TARGET  := test_ismm
SRCS    := ISMM.c stubs.c

.PHONY: all test clean

all: $(TARGET)

$(TARGET): $(SRCS) ISMM.h
	$(CC) $(CFLAGS) -o $@ $(SRCS)

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET)
